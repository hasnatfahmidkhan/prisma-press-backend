model User {
    id           String       @id @default(uuid())
    name         String       @db.VarChar(255)
    email        String       @unique
    password     String
    activeStatus ActiveStatus @default(ACTIVE)
    role         Role         @default(USER)
    created_at   DateTime     @default(now())
    udpated_at   DateTime     @updatedAt

    profileId Profile?

    @@map("users")
}
